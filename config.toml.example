[telegram]
bot_token = "YOUR_BOT_TOKEN"
# owner_id = 123456789  # STRONGLY RECOMMENDED: Owner user ID (highest privilege)
                         # In production or any internet-exposed deployment, you MUST set this explicitly.
                         # If left unset, the first user to talk to the bot will automatically become owner.
                         # Only rely on this auto-assignment in tightly controlled environments where you can
                         # guarantee the first interaction is from the deployer. On a public bot, leaving this
                         # unset can allow an attacker who finds the bot first to seize full control.
bot_mode = "private"  # Bot mode: "private" (chats disabled by default) or "public" (chats enabled by default)
# api_url = "https://api.telegram.org"  # Optional: Custom Telegram API URL (e.g., for local bot API server)
# require_mention_in_group = true  # Whether bot requires @mention to respond in groups (default: true)
                                   # Set to false to allow bot to respond without @mention in groups
                                   # Note: Each chat can override this via /settings → "群组命令响应"
                                   # When enabled globally, individual chats can still allow responses without @mention

[pixiv]
refresh_token = "YOUR_PIXIV_REFRESH_TOKEN"

[database]
url = "sqlite:./data/pixivbot.db?mode=rwc"

[logging]
level = "info"
dir = "./data/logs"

[scheduler]
# Tick interval in seconds (how often to check for pending tasks)
tick_interval_sec = 30
# Random interval range for task execution (in seconds)
# Default: 2-3 hours
min_task_interval_sec = 7200
max_task_interval_sec = 10800
# Cache retention period in days (how long to keep downloaded images)
cache_retention_days = 7
# Cache directory path for downloaded images
cache_dir = "data/cache"
# Maximum retry count for failed pushes (default: 3, <=0 means no retry)
max_retry_count = 3
# Ranking task execution time in HH:MM format (default: "19:00" local time)
ranking_execution_time = "19:00"
# Author name update time in HH:MM format (default: "21:00" local time)
# Updates subscribed author names daily to sync with Pixiv profile changes
author_name_update_time = "21:00"

[content]
# Default sensitive tags for new chats. Each chat can customize their own sensitive tags.
# When blur_sensitive is enabled for a chat, images containing these tags will be spoiler-blurred.
sensitive_tags = ["R-18", "R-18G", "NSFW"]
# Default image size for push notifications: "original", "large", "medium", or "square_medium"
# Default: "large" (balances quality and size)
# Note: Download feature always uses original size
image_size = "large"
# Threshold for sending original images in download command (1-10)
# When total images <= this value, send each image separately as original files
# When total images > this value, pack all images into a ZIP file
# Default: 1 (only single-image works are sent as original files)
download_original_threshold = 1

# ----------------------------------------------------------------------------
# Booru sites (optional). Add one [[booru.sites]] block per site to subscribe.
# ----------------------------------------------------------------------------
# [[booru.sites]]
# name = "yandere"                       # Unique short identifier used in commands
# engine_type = "moebooru"               # "moebooru" | "danbooru" | "gelbooru"
# base_url = "https://yande.re"
# # username = "your_username"           # Optional: API auth
# # api_key  = "your_api_key"
# min_interval_sec = 1800                # Min poll interval per subscription (default 1800)
# max_interval_sec = 3600                # Max poll interval per subscription (default 3600)
# page_limit = 20                        # Posts fetched per poll (default 20)
#
# # Optional: route this site's API requests through FlareSolverr to bypass
# # Cloudflare's JavaScript challenge / Turnstile auto-pass. FlareSolverr is a
# # separately-deployed service: https://github.com/FlareSolverr/FlareSolverr
# # NOTE: Image hotlinks are fetched by Telegram's servers, not by the bot,
# # so the bypass only protects API calls. If a site's image CDN is also
# # CF-protected and Telegram fails to fetch images, this option will not help.
# # Interactive captchas (visible reCAPTCHA / hCaptcha) are NOT supported.
# # bypass = { mode = "flaresolverr", endpoint = "http://flaresolverr:8191/v1", max_timeout_ms = 60000 }
# # Optional: reuse a long-lived FlareSolverr session for lower latency.
# # The session must be created out-of-band via FlareSolverr's `sessions.create`.
# # bypass = { mode = "flaresolverr", endpoint = "http://flaresolverr:8191/v1", max_timeout_ms = 60000, session = "pixivbot" }

# ----------------------------------------------------------------------------
# E-Hentai / ExHentai (optional). Uncomment and configure to enable EH
# gallery subscription and direct download features.
# ----------------------------------------------------------------------------
# [ehentai]
# # Site: "e-hentai" (public, no auth required) or "exhentai" (requires cookies)
# site = "e-hentai"
# # Required for exhentai, recommended for e-hentai:
# # ipb_member_id = "12345"
# # ipb_pass_hash = "abcdef0123456789abcdef0123456789"
# # igneous = "abcdef"           # Required for exhentai only
# # Image resolution for subscription archive downloads:
# #   "780x", "980x", "1280x" (free resamples), "1600x"/"2400x" (donors),
# #   "original" (logged-in, costs GP/credits)
# subscription_resolution = "1280x"
# # Image resolution for /edl direct downloads (default: "1280x")
# download_resolution = "1280x"
# # Send archive ZIP to chat (default: true)
# send_archive = true
# # Upload to Telegraph and send link for subscription updates (default: false)
# upload_telegraph = false
# # Poll interval range (seconds) for subscription checks
# min_interval_sec = 1800        # default: 30 min
# max_interval_sec = 3600        # default: 1 hour
# # Optional: Telegraph access token for Telegraph upload feature
# # telegraph_access_token = "your_telegraph_token"
# # Max galleries to push per tick (default: 3)
# max_push_per_tick = 3
# # Max retry count for failed pushes (default: 3)
# max_retry_count = 3
# # 48h scan window for rating-filtered subscriptions (default: 48)
# scan_window_hours = 48
# # Download rate limiting (default: 7 GB per 7 days / 168 hours)
# download_rate_limit_gb = 7
# download_rate_window_hours = 168
# # Poll interval for download processor (seconds, default: 60)
# download_poll_interval_sec = 60
# # Max pushed GIDs to remember per subscription (default: 500)
# pushed_cap = 500
